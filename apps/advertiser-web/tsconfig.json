{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@repo/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@repo/shared-types/*": [
        "../../packages/shared-types/src/*"
      ],
      "@repo/api": [
        "../../packages/api/src/index.ts"
      ],
      "@repo/api/*": [
        "../../packages/api/src/*"
      ],
      "@repo/ui/*": [
        "../../packages/ui-components/*"
      ],
      "@repo/ui-components": [
        "../../packages/ui-components/src/index.ts"
      ],
      "@repo/ui-components/*": [
        "../../packages/ui-components/src/*"
      ],
      "@repo/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@repo/utils/*": [
        "../../packages/utils/src/*"
      ],
      "@repo/hooks": [
        "../../packages/hooks/src/index.ts"
      ],
      "@repo/hooks/*": [
        "../../packages/hooks/src/*"
      ]
    },
    "types": [
      "vite/client",
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}