{
    "name": "ad-multi-platform",
    "private": true,
    "description": "Cross-platform advertising system monorepo",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build && tsc --noEmit",
        "lint": "turbo run lint && eslint . --max-warnings 0",
        "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
        "test": "turbo run test",
        "prepare": "husky install"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.36.1",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "husky": "^8.0.0",
        "prettier": "^3.0.0",
        "turbo": "latest",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.56.1"
    },
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=8.0.0"
    },
    "packageManager": "pnpm@9.15.4"
}