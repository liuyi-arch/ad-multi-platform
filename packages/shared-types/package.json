{
    "name": "@repo/shared-types",
    "version": "0.0.0",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc --build"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
