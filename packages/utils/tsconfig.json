{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "emitDeclarationOnly": false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/**/*"
  ],
  "references": [
    {
      "path": "../shared-types"
    }
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}